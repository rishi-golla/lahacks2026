# ASI:One / Agentverse agent
PURCHASE_AGENT_NAME=local-chrome-purchase-agent
AGENT_SEED=replace-with-agent-seed
AGENT_PORT=8001
AGENT_ENDPOINT=http://127.0.0.1:8002/submit
AGENT_MAILBOX=true
PUBLISH_AGENT_DETAILS=true

# Local Playwright MCP server, started separately with:
# npx @playwright/mcp@latest --port 8931 --browser=chrome
PLAYWRIGHT_MCP_URL=http://127.0.0.1:8931/mcp
PLAYWRIGHT_MCP_TIMEOUT_S=180

# Gemini model configuration for the local Playwright MCP tool loop
GEMINI_API_KEY=replace-with-gemini-api-key
MODEL_API_KEY=optional-back-compat-gemini-key
PURCHASE_AGENT_MODEL=gemini-2.5-flash

# Amazon automation safety/configuration
AMAZON_URL=https://www.amazon.com
PURCHASE_MAX_TOTAL_USD=
