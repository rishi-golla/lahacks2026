# ASI:One / Agentverse agent
PURCHASE_AGENT_NAME=browserbase-purchase-agent
AGENT_SEED=replace-with-agent-seed
AGENT_PORT=8001
AGENT_ENDPOINT=http://127.0.0.1:8002/submit
AGENT_MAILBOX=true
PUBLISH_AGENT_DETAILS=true

# Browserbase purchase worker
PURCHASE_WORKER_URL=http://127.0.0.1:8003/v1/purchase/review
PURCHASE_WORKER_TIMEOUT_S=120
PURCHASE_WORKER_PORT=8003

# Browserbase session credentials
BROWSERBASE_API_KEY=replace-with-browserbase-api-key
BROWSERBASE_PROJECT_ID=replace-with-browserbase-project-id
BROWSERBASE_CONTEXT_ID=replace-with-browserbase-context-id
BROWSERBASE_USE_PROXY=0
BROWSERBASE_PROXY_CITY=
BROWSERBASE_PROXY_STATE=
BROWSERBASE_PROXY_COUNTRY=

# Stagehand model configuration
MODEL_API_KEY=replace-with-model-provider-api-key
STAGEHAND_MODEL_NAME=google/gemini-3-flash-preview
STAGEHAND_DOM_SETTLE_TIMEOUT_MS=5000
STAGEHAND_VERBOSE=1

# Amazon automation safety/configuration
AMAZON_URL=https://www.amazon.com
PURCHASE_MAX_TOTAL_USD=