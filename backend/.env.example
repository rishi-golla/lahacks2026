# Required for Phase 4: backend -> Gemini Live.
# Get a key from Google AI Studio, then copy this file to `.env`.
GEMINI_API_KEY=

# Gemini Live model. This one supports async/NON_BLOCKING tools for later stages.
GEMINI_LIVE_MODEL=gemini-live-2.5-flash-preview

# Development server defaults.
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
