# Required for Phase 4: backend -> Gemini Live.
# Get a key from Google AI Studio, then copy this file to `.env`.
GEMINI_API_KEY=

# Gemini Live model for Google AI Studio API keys.
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Development server defaults.
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO

# Native-audio Gemini Live models require audio responses; transcripts are derived.
GEMINI_RESPONSE_MODALITIES=AUDIO

# Optional local debugging: dump every received JPEG to this ignored directory.
# SESSION_PHOTO_DUMP_DIR=debug-photos
